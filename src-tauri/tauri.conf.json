{
  "productName": "Agent Token Tracker",
  "version": "0.1.0",
  "identifier": "com.atk.desktop",
  "build": {
    "beforeDevCommand": "echo 'Using manual dev server'",
    "beforeBuildCommand": "npm run --prefix ../frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
